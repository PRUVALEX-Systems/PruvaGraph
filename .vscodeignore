# ─────────────────────────────────────────────
# PRUVALEX PruvaGraph — .vscodeignore
# Excludes everything NOT needed in the .vsix
# ─────────────────────────────────────────────

# Python backend (installed separately via pip)
python/**

# Build scripts & CI
scripts/**
.github/**

# Already-built VSIX files
dist/**
*.vsix

# Dev tooling
node_modules/**
.vscode/**
.vscode-test/**
*.test.js
*.spec.js

# Husky / git hooks
.husky/**

# Graph output cache
pruvagraph-out/**

# Random images (keep only icon.png which is required by the manifest)
*.jpeg
*.jpg
105bc64f-92a7-49fc-a9ac-067cfb535a1e.png
4k_resolution_Mein_Do_2K_202606160058.jpeg
upgrade_karo_aur_4k_resolution_202606160006.jpeg
{200E29D6-0563-49C2-AC1E-3329B1A816BF}.png

# Source control
.git/**
.gitignore

# Docs (keep README + CHANGELOG in vsix)
*.md
!README.md
!CHANGELOG.md

# OS noise
.DS_Store
Thumbs.db
Thumbs.db:encryptable
desktop.ini
