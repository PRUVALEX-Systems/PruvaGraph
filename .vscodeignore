# .vscodeignore for PRUVALEX PruvaGraph
# Strategy: exclude everything (**), then whitelist only runtime files.
# This keeps VSIX lean (< 1 MB target).

**
!package.json
!README.md
!LICENSE
!CHANGELOG.md
!icon.png
!dist/extension.js
!extension-savings-receipt.js
!extension-mcp-server.js
!media/**

# ── Exclude everything else ──────────────────────────────────
.git/**
.gitignore
.gitmessage
node_modules/**
.node_modules/**
python/**
.venv/**
.vscode/**
.vscode-test/**
.github/**
.husky/**
.opencode/**
docs/**
scripts/**
benchmarks/**
tests/**
test/**
test-workspace/**
coverage/**
legacy/**
omnimcp/**
PruvaGraph/**
pruvagraph-out/**
dist/**
.mypy_cache/**
.pytest_cache/**
.ruff_cache/**
*.vsix
*.zip
*.log
*.tmp
*.temp
*.map
*.ts
*.tsx
*.yml
*.yaml
*.coverage
.DS_Store
Thumbs.db
desktop.ini
analyzer.js
gemini-svg*.svg
