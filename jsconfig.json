{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "vscode": ["./node_modules/@types/vscode"]
    }
  },
  "include": [
    "extension.js",
    "src/**/*.js",
    "build.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".vscode-test",
    "python",
    "PruvaGraph"
  ]
}
